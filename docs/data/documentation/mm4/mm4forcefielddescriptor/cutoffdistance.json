{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Required. The cutoff to use for nonbonded interactions."}],"metadata":{"symbolKind":"property","title":"cutoffDistance","role":"symbol","modules":[{"name":"MM4"}],"externalID":"s:3MM40A20ForceFieldDescriptorV14cutoffDistanceSfvp","roleHeading":"Instance Property","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"cutoffDistance"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"}]},"hierarchy":{"paths":[["doc:\/\/MM4\/documentation\/MM4","doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldDescriptor"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"cutoffDistance"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value is 1.0 nm. This is 2.86σ for carbon and 2.45σ for"},{"type":"text","text":" "},{"type":"text","text":"silicon."}]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"This documentation page is still a draft. It may be inconsistent or"},{"type":"text","text":" "},{"type":"text","text":"difficult to understand."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since germanium will rarely be used, use the 2.5σ cutoff for silicon. The"},{"type":"text","text":" "},{"type":"text","text":"slightly greater sigma for carbon allows greater accuracy in vdW forces"},{"text":" ","type":"text"},{"text":"for bulk diamond. 1.0 nm is also sufficient for charge-charge","type":"text"},{"type":"text","text":" "},{"text":"interact