{"identifier":{"url":"doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MM4ForceFieldEnergy","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"This documentation page is still a draft. It may be inconsistent or"},{"type":"text","text":" "},{"text":"difficult to understand.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"We always report energy, time, and unit conversion constants in double"},{"text":" ","type":"text"},{"type":"text","text":"precision. Potential energy can sometimes have a massive absolute value"},{"type":"text","text":" "},{"text":"that dwarfs the magnitude of relative values.","type":"text"},{"type":"text","text":" "},{"text":"Everything else, including rigid body bulk properties susceptible to the","type":"text"},{"type":"text","text":" "},{"text":"same degree of rounding error, are reported in single precision. Force","type":"text"},{"type":"text","text":" "},{"type":"text","text":"field parameters and similar quantities (heat capacity) are in single"},{"type":"text","text":" "},{"text":"precision because we don’t know their value with a lot of certainty.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, some internal summation algorithms temporarily employ mixed"},{"type":"text","text":" "},{"text":"precision. Both the CPU code for ","type":"text"},{"code":"MM4RigidBody","type":"codeVoice"},{"type":"text","text":" and GPU code for the OpenMM"},{"text":" ","type":"text"},{"type":"text","text":"Metal plugin use block summation. The majority of the compute cost happens"},{"type":"text","text":" "},{"type":"text","text":"on FP32, either to improve execution speed and reduce register pressure"},{"text":" ","type":"text"},{"type":"text","text":"(CPU) or provide compatibility with a specific hardware vendor (GPU). The"},{"type":"text","text":" "},{"type":"text","text":"rounding error is capped to whatever error occurs within a block"},{"text":" ","type":"text"},{"type":"text","text":"(~1000 elements). Outside of the block, the number is casted to"},{"type":"text","text":" "},{"type":"text","text":"FP64 and summed with no additional rounding error. This prevents unexpected"},{"type":"text","text":" "},{"type":"text","text":"issues popping up with large systems that exceed 1000 elements. The mantissa"},{"text":" ","type":"text"},{"text":"of the quantity is still ~32 bits; we just prevent it from degrading to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"something like ~16 bits."}]}]}],"hierarchy":{"paths":[["doc:\/\/MM4\/documentation\/MM4"]]},"metadata":{"externalID":"s:3MM40A16ForceFieldEnergyV","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MM4ForceFieldEnergy","kind":"identifier"}],"title":"MM4ForceFieldEnergy","symbolKind":"struct","role":"symbol","modules":[{"name":"MM4"}],"navigatorTitle":[{"kind":"identifier","text":"MM4ForceFieldEnergy"}],"roleHeading":"Structure"},"variants":[{"paths":["\/documentation\/mm4\/mm4forcefieldenergy"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"A data structure wrapping a system’s energy."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"topicSections":[{"title":"Instance Properties","identifiers":["doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy\/kinetic","doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy\/potential"]}],"references":{"doc://MM4/documentation/MM4/MM4ForceFieldEnergy/kinetic":{"role":"symbol","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy\/kinetic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"kinetic","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"type":"topic","abstract":[{"type":"text","text":"The system’s total kinetic energy, in zeptojoules."}],"title":"kinetic","url":"\/documentation\/mm4\/mm4forcefieldenergy\/kinetic","kind":"symbol"},"doc://MM4/documentation/MM4/MM4ForceFieldEnergy":{"abstract":[{"text":"A data structure wrapping a system’s energy.","type":"text"}],"identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MM4ForceFieldEnergy"}],"navigatorTitle":[{"text":"MM4ForceFieldEnergy","kind":"identifier"}],"title":"MM4ForceFieldEnergy","url":"\/documentation\/mm4\/mm4forcefieldenergy"},"doc://MM4/documentation/MM4/MM4ForceFieldEnergy/potential":{"title":"potential","kind":"symbol","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy\/potential","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"potential"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"The system’s total potential energy, in zeptojoules."}],"role":"symbol","url":"\/documentation\/mm4\/mm4forcefieldenergy\/potential","type":"topic"},"doc://MM4/documentation/MM4":{"role":"collection","identifier":"doc:\/\/MM4\/documentation\/MM4","type":"topic","url":"\/documentation\/mm4","kind":"symbol","title":"MM4","abstract":[{"type":"text","text":"The MM2 force field used to create "},{"inlineContent":[{"text":"Nanosystems (1992)","type":"text"}],"type":"emphasis"},{"text":", but updated with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"modern ab initio calculations."}]}}}