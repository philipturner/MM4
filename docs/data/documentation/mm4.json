{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mm4"]}],"hierarchy":{"paths":[[]]},"abstract":[{"text":"Molecular Mechanics force field, version 4. The simulator used to create ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Nanosystems (1992)","type":"text"}]},{"type":"text","text":", but updated with modern ab initio parameters."}],"metadata":{"roleHeading":"Framework","title":"MM4","symbolKind":"module","role":"collection","modules":[{"name":"MM4"}],"externalID":"MM4"},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/MM4\/documentation\/MM4"},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/MM4\/documentation\/MM4\/MM4ForceField"],"title":"Classes"},{"title":"Structures","identifiers":["doc:\/\/MM4\/documentation\/MM4\/MM4Address","doc:\/\/MM4\/documentation\/MM4\/MM4AngleExtendedParameters","doc:\/\/MM4\/documentation\/MM4\/MM4AngleParameters","doc:\/\/MM4\/documentation\/MM4\/MM4Angles","doc:\/\/MM4\/documentation\/MM4\/MM4AtomParameters","doc:\/\/MM4\/documentation\/MM4\/MM4Atoms","doc:\/\/MM4\/documentation\/MM4\/MM4BondExtendedParameters","doc:\/\/MM4\/documentation\/MM4\/MM4BondParameters","doc:\/\/MM4\/documentation\/MM4\/MM4Bonds","doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldDescriptor","doc:\/\/MM4\/documentation\/MM4\/MM4ForceFieldEnergy","doc:\/\/MM4\/documentation\/MM4\/MM4ForceOptions","doc:\/\/MM4\/documentation\/MM4\/MM4Parameters","doc:\/\/MM4\/documentation\/MM4\/MM4ParametersDescriptor","doc:\/\/MM4\/documentation\/MM4\/MM4RigidBody","doc:\/\/MM4\/documentation\/MM4\/MM4RigidBodyDescriptor","doc:\/\/MM4\/documentation\/MM4\/MM4Rings","doc:\/\/MM4\/documentation\/MM4\/MM4State","doc:\/\/MM4\/documentation\/MM4\/MM4StateDescriptor","doc:\/\/MM4\/documentation\/MM4\/MM4TorsionExtendedParameters","doc:\/\/MM4\/documentation\/MM4\/MM4TorsionParameters","doc:\/\/MM4\/documentation\/MM4\/MM4Torsions"]},{"identifiers":["doc:\/\/MM4\/documentation\/MM4\/MM4AJPerKJPerMol","doc:\/\/MM4\/documentation\/MM4\/MM4AJPerZJ","doc:\/\/MM4\/documentation\/MM4\/MM4AmuPerYg","doc:\/\/MM4\/documentation\/MM4\/MM4DebyePerEAngstrom","doc:\/\/MM4\/documentation\/MM4\/MM4EAngstromPerDebye","doc:\/\/MM4\/documentation\/MM4\/MM4KJPerMolPerAJ","doc:\/\/MM4\/documentation\/MM4\/MM4KJPerMolPerZJ","doc:\/\/MM4\/documentation\/MM4\/MM4YgPerAmu","doc:\/\/MM4\/documentation\/MM4\/MM4ZJPerAJ","doc:\/\/MM4\/documentation\/MM4\/MM4ZJPerKJPerMol"],"title":"Variables"},{"title":"Enumerations","identifiers":["doc:\/\/MM4\/documentation\/MM4\/MM4AtomCode","doc:\/\/MM4\/documentation\/MM4\/MM4CenterType","doc:\/\/MM4\/documentation\/MM4\/MM4Error","doc:\/\/MM4\/documentation\/MM4\/MM4IntegratorOptions"]}],"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simulator supports the atoms enumerated by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4AtomCode"},{"text":", with some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"restrictions on permitted bond types. Elements except C, Si, Ge must have"},{"type":"text","text":" "},{"type":"text","text":"every covalent bond shared with a carbon atom. In addition, no dissimilar"},{"text":" ","type":"text"},{"text":"non-H\/C atoms may be separated by a bond once removed. Within these","type":"text"},{"type":"text","text":" "},{"type":"text","text":"restrictions, there exists a large variety of permissible structures, more"},{"type":"text","text":" "},{"type":"text","text":"than with exclusively carbon and hydrogen."}]},{"type":"paragraph","inlineContent":[{"text":"All force terms from MM3, and most terms from MM4, are included, except:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Electronegativity effect correction to equilibrium bond angle"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Electronegativity effect correction to bond stretching stiffness"}]}]},{"content":[{"inlineContent":[{"text":"Torsion-torsion interaction","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Bend-torsion-bend interaction in bulk diamond","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"All major platforms (Mac, Linux, Windows) and all major GPU architectures","type":"text"},{"type":"text","text":" "},{"text":"(Apple, AMD, Intel, Nvidia) are supported. This includes multi-GPU systems","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with up to around a dozen GPUs (e.g. a single supercomputer node). This is"},{"text":" ","type":"text"},{"text":"because it delegates all of the computation to OpenMM, an existing,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"well-tested framework for easily porting molecular simulation algorithms to"},{"type":"text","text":" "},{"text":"multiple vendors. OpenMM avoids any O(n^3) algorithms and provides the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"flexibility to opt out of O(n^2) algorithms."}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"Throughout the entire software stack, from setup to minimization to","type":"text"},{"type":"text","text":" "},{"text":"simulation, this simulator is O(n). Linear scaling exists at every system","type":"text"},{"type":"text","text":" "},{"text":"size and material composition. This is a rarity among simulation","type":"text"},{"type":"text","text":" "},{"text":"algorithms, most of which are inherently O(n^2) or","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/xtb-docs.readthedocs.io\/en\/latest\/gfnff.html","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Molecular mechanics is one of the few techniques that can simulate"},{"text":" ","type":"text"},{"type":"text","text":"million-atom nanosystems on affordable hardware."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"The simulator uses 32-bit single precision and an NVE ensemble. Single","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"precision is often associated with poor energy conservation. However, the"},{"text":" ","type":"text"},{"text":"reason for using NVE is not energy conservation. The default time step is","type":"text"},{"type":"text","text":" "},{"text":"so large that integration error dwarfs rounding error. Switching to 64-bit","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"double precision would not improve energy conservation."}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"Accuracy (whether an archer hits the right target) is orthogonal"},{"type":"text","text":" "},{"text":"to precision (whether the arrows hit the same place every time).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Conservation of energy only affects the number of significant figures of"},{"text":" ","type":"text"},{"type":"text","text":"measured energy (precision). It does not make system dynamics more"},{"type":"text","text":" "},{"text":"accurate, except in the case where energy systematically drifts upward.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Single precision is an implementation choice to make the simulator more"},{"type":"text","text":" "},{"text":"compatible with different GPU architectures. Most vendors have no or few","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"FP64 units (unlike CPU, where FP64 is widely supported). Mixed precision"},{"text":" ","type":"text"},{"text":"can sometimes run the bulk of computations in FP32, with only the energy","type":"text"},{"type":"text","text":" "},{"text":"computations in FP64. However, even mixed precision has implementation","type":"text"},{"text":" ","type":"text"},{"text":"issues, being difficult to run on GPUs with zero FP64 units.","type":"text"}]}],"kind":"content"}],"references":{"doc://MM4/documentation/MM4/MM4DebyePerEAngstrom":{"url":"\/documentation\/mm4\/mm4debyepereangstrom","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4DebyePerEAngstrom","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"4.803205"}],"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MM4DebyePerEAngstrom"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"}],"title":"MM4DebyePerEAngstrom","type":"topic"},"doc://MM4/documentation/MM4/MM4Atoms":{"identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4Atoms","url":"\/documentation\/mm4\/mm4atoms","navigatorTitle":[{"text":"MM4Atoms","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MM4Atoms","kind":"identifier"}],"abstract":[{"type":"text","text":"Parameters for one atom."}],"kind":"symbol","title":"MM4Atoms","type":"topic","role":"symbol"},"doc://MM4/documentation/MM4/MM4RigidBodyDescriptor":{"url":"\/documentation\/mm4\/mm4rigidbodydescriptor","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4RigidBodyDescriptor","role":"symbol","navigatorTitle":[{"text":"MM4RigidBodyDescriptor","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"A configuration for a rigid body.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"MM4RigidBodyDescriptor","kind":"identifier"}],"title":"MM4RigidBodyDescriptor","type":"topic"},"doc://MM4/documentation/MM4/MM4KJPerMolPerZJ":{"fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MM4KJPerMolPerZJ"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Doub