"text":"MM4StateDescriptor","kind":"identifier"}],"abstract":[{"type":"text","text":"A configuration for a frame of a simulation."}],"kind":"symbol","navigatorTitle":[{"text":"MM4StateDescriptor","kind":"identifier"}],"url":"\/documentation\/mm4\/mm4statedescriptor","title":"MM4StateDescriptor","role":"symbol","type":"topic"},"doc://MM4/documentation/MM4/MM4BoltzInZJPerK":{"url":"\/documentation\/mm4\/mm4boltzinzjperk","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4BoltzInZJPerK","role":"symbol","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MM4BoltzInZJPerK","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"abstract":[{"text":"0.013806","type":"text"}],"title":"MM4BoltzInZJPerK","type":"topic"},"doc://MM4/documentation/MM4/MM4Int8Vector":{"abstract":[],"kind":"symbol","type":"topic","url":"\/documentation\/mm4\/mm4int8vector","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4Int8Vector","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"MM4Int8Vector"}],"navigatorTitle":[{"text":"MM4Int8Vector","kind":"identifier"}],"title":"MM4Int8Vector","role":"symbol"},"doc://MM4/documentation/MM4/MM4DebyePerEAngstrom":{"role":"symbol","kind":"symbol","type":"topic","abstract":[{"text":"4.803205","type":"text"}],"title":"MM4DebyePerEAngstrom","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"MM4DebyePerEAngstrom","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4DebyePerEAngstrom","url":"\/documentation\/mm4\/mm4debyepereangstrom"},"doc://MM4/documentation/MM4/MM4VectorWidth":{"url":"\/documentation\/mm4\/mm4vectorwidth","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"The vector width may be architecture-specific due to compiler macros."}],"role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MM4VectorWidth","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"MM4VectorWidth","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4VectorWidth"},"doc://MM4/documentation/MM4/MM4Int16Vector":{"identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4Int16Vector","type":"topic","url":"\/documentation\/mm4\/mm4int16vector","role":"symbol","abstract":[],"kind":"symbol","title":"MM4Int16Vector","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"MM4Int16Vector","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MM4Int16Vector"}]},"doc://MM4/documentation/MM4/MM4Torsions":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MM4Torsions","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4Torsions","navigatorTitle":[{"text":"MM4Torsions","kind":"identifier"}],"role":"symbol","title":"MM4Torsions","abstract":[{"text":"Parameters for a group of 4 atoms.","type":"text"}],"url":"\/documentation\/mm4\/mm4torsions"},"doc://MM4/documentation/MM4/MM4Int64Vector":{"identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4Int64Vector","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MM4Int64Vector"}],"abstract":[],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MM4Int64Vector"}],"type":"topic","kind":"symbol","url":"\/documentation\/mm4\/mm4int64vector","title":"MM4Int64Vector"},"doc://MM4/documentation/MM4/MM4State":{"navigatorTitle":[{"text":"MM4State","kind":"identifier"}],"kind":"symbol","title":"MM4State","role":"symbol","abstract":[{"type":"text","text":"A frame of a simulation."}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MM4State","kind":"identifier"}],"url":"\/documentation\/mm4\/mm4state","type":"topic","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4State"},"doc://MM4/documentation/MM4/MM4ForceOptions":{"url":"\/documentation\/mm4\/mm4forceoptions","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MM4ForceOptions","kind":"identifier"}],"title":"MM4ForceOptions","abstract":[],"type":"topic","kind":"symbol","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4ForceOptions","navigatorTitle":[{"text":"MM4ForceOptions","kind":"identifier"}],"role":"symbol"},"doc://MM4/documentation/MM4/MM4KJPerMolPerZJ":{"url":"\/documentation\/mm4\/mm4kjpermolperzj","title":"MM4KJPerMolPerZJ","type":"topic","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MM4KJPerMolPerZJ"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"role":"symbol","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4KJPerMolPerZJ","abstract":[{"type":"text","text":"0.602214"}]},"doc://MM4/documentation/MM4/MM4ZJPerAJ":{"url":"\/documentation\/mm4\/mm4zjperaj","abstract":[{"text":"1000","type":"text"}],"title":"MM4ZJPerAJ","identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4ZJPerAJ","role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"MM4ZJPerAJ","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}]},"doc://MM4/documentation/MM4/MM4Parameters":{"kind":"symbol","title":"MM4Parameters","navigatorTitle":[{"text":"MM4Parameters","kind":"identifier"}],"role":"symbol","type":"topic","url":"\/documentation\/mm4\/mm4parameters","abstract":[{"text":"A set of force field parameters.","type":"text"}],"identifier":"doc:\/\/MM4\/documentation\/MM4\/MM4Parameters","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MM4Parameters"}]},"doc://MM4/documentation/MM4/